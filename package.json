{
  "name": "taskpipe",
  "private": true,
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'apps/**/*.ts' 'packages/**/*.ts'",
    "format": "prettier --write 'apps/**/*.ts' 'packages/**/*.ts'",
    "format:check": "prettier --check 'apps/**/*.ts' 'packages/**/*.ts'"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "9",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "vitest": "^4.1.5"
  }
}
